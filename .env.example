# ----- Caché (igual que Tarea 2) -----
CACHE_SIZE=200mb
POLICY=lru

# ----- Generador de tráfico / escenarios -----
DIST=zipf
N_CONSULTAS=1000
RATE=50
NUM_CONSUMERS=2
MAX_RETRIES=3
RETRY_BACKOFF_MS=500
FAILURE_RATE=0.0
LATENCY_MS=0
DOWN_AT=-1
DOWN_DURATION=0
SPIKE=0
SPIKE_FACTOR=10
SPIKE_AT=0.5
SPIKE_DURATION=5
CONSUMER_GROUP=consumidor-grupo

# ----- Spark Structured Streaming (nuevo en T3) -----
ES_INDEX=metrics-aggregated
WINDOW_DURATION=60 seconds
SLIDE_DURATION=30 seconds
WATERMARK=2 minutes
TRIGGER_INTERVAL=10 seconds
STARTUP_DELAY=25
